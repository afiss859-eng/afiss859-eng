# ╔═━━━⟬ 𓅂 LUCIFERO BOT CONFIG 𓅂 ⟭━━━═╗
# Configuration du bot - Copier en config.env

# ═══ OWNER ═══
OWNER_NUMBER=221771234567
OWNER_NAME=𝐒𝐀𝐊𝐀𝐌𝐎𝐓𝐎 DEV TECH

# ═══ BOT ═══
BOT_NAME=𓅂𝐃𝚯𝐌𝚫 𝐋𝐔𝐂𝐈𝐅𝚵𝐑𝚯 𓅂
BOT_VERSION=1.0.0
PREFIX=.

# ═══ MODE ═══
# public = tout le monde peut utiliser le bot
# private = seulement l'owner et les admins
MODE=public

# ═══ PARAMÈTRES AUTO ═══
AUTO_READ=false
AUTO_STATUS=false
ANTI_CALL=true
ANTI_SPAM=true
PM_BLOCKER=false

# ═══ IA (optionnel) ═══
OPENAI_API_KEY=
GEMINI_API_KEY=

# ═══ SESSION ═══
# Laisser vide pour une nouvelle session (connexion via pair code)
SESSION_ID=
